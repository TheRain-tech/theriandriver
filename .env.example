# ─── Firebase Client SDK ─────────────────────────────────────────────────────
# Project: therain-production (shared with Rider app, Admin dashboard)
# flutter pub run build_runner build, or set via --dart-define-from-file=.env
FIREBASE_API_KEY=AIzaSyB6MRrPC_O6uhhE7GtoMEolRH2EQhbD0tk
FIREBASE_PROJECT_ID=therain-production
FIREBASE_STORAGE_BUCKET=therain-production.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=8765794703
FIREBASE_APP_ID=1:8765794703:android:ac25ebaa59abc10be7c3fa
GOOGLE_MAPS_API_KEY=replace-with-your-google-maps-android-key
# OAuth 2.0 "Web client" ID from Firebase Console > Project Settings > Your apps
# > com.therain.driver > SHA certificate fingerprints (add one first, this
# field then appears). Required for Google Sign-In to return an ID token.
GOOGLE_SERVER_CLIENT_ID=replace-with-your-oauth-web-client-id.apps.googleusercontent.com

# ─── Backend API (TheRain node-api) ──────────────────────────────────────────
# Production: https://node-api-production-3f5f.up.railway.app
# Local dev:  http://localhost:8080
API_BASE_URL=https://node-api-production-3f5f.up.railway.app

# ─── Feature flags ───────────────────────────────────────────────────────────
ENABLE_PREVIEW_MODE=false
ENABLE_MOCK_FALLBACK=false
ENABLE_GOOGLE_SIGN_IN=true
