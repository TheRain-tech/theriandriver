rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function roleIs(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isRider() {
      return roleIs('rider');
    }

    function isDriver() {
      return roleIs('driver');
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || roleIs('admin')
        );
    }

    function isFleetOwner() {
      return roleIs('fleet_owner') || roleIs('enterprise');
    }

    function driverDoc(driverId) {
      return get(/databases/$(database)/documents/drivers/$(driverId));
    }

    function driverProfileMatchesAuth(driverId) {
      return signedIn()
        && exists(/databases/$(database)/documents/drivers/$(driverId))
        && (
          driverId == request.auth.uid
          || driverDoc(driverId).data.authUid == request.auth.uid
        );
    }

    function fleetOwnedByCaller(fleetId) {
      return isFleetOwner()
        && exists(/databases/$(database)/documents/fleets/$(fleetId))
        && get(/databases/$(database)/documents/fleets/$(fleetId)).data.fleetOwnerId == request.auth.uid;
    }

    function requestBelongsToRider(requestId) {
      return exists(/databases/$(database)/documents/ride_requests/$(requestId))
        && get(/databases/$(database)/documents/ride_requests/$(requestId)).data.riderId == request.auth.uid;
    }

    function rideBelongsToRider(rideId) {
      return exists(/databases/$(database)/documents/rides/$(rideId))
        && get(/databases/$(database)/documents/rides/$(rideId)).data.riderId == request.auth.uid;
    }

    function validDriverVerificationTransition() {
      return request.resource.data.verificationStatus == resource.data.verificationStatus
        || (
          resource.data.verificationStatus == 'notStarted'
          && request.resource.data.verificationStatus == 'inProgress'
        )
        || (
          resource.data.verificationStatus in [
            'inProgress',
            'rejected',
            'resubmissionRequired'
          ]
          && request.resource.data.verificationStatus == 'pending'
        );
    }

    function validRideTransition(before, after) {
      return (before == 'driver_assigned' && after == 'driver_arriving')
        || (before == 'driver_arriving' && after == 'driver_arrived')
        || (before == 'driver_arrived' && after == 'in_progress')
        || (before == 'in_progress' && after == 'completed')
        || (
          before in ['driver_assigned', 'driver_arriving', 'driver_arrived']
          && after in ['cancelled_by_driver', 'cancelled_by_rider']
        );
    }

    match /users/{userId} {
      allow create: if owns(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ['rider', 'driver']
        && request.resource.data.status == 'active';
      allow read: if owns(userId) || isAdmin();
      allow update: if owns(userId)
        && resource.data.uid == request.resource.data.uid
        && resource.data.role == request.resource.data.role
        && resource.data.status == request.resource.data.status
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullName',
          'phoneNumber',
          'email',
          'profileImageUrl',
          'photoUrl',
          'updatedAt',
          'lastLoginAt',
          'lastLogin',
          'deviceInfo',
          'isLocationEnabled',
          'currentLocation'
        ]);
      allow delete: if false;

      match /fcmTokens/{tokenId} {
        allow read, create, update: if owns(userId);
        allow delete: if owns(userId);
      }
    }

    match /riders/{riderId} {
      allow create: if owns(riderId)
        && request.resource.data.userId == request.auth.uid;
      allow read: if owns(riderId) || isAdmin();
      allow update: if owns(riderId)
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['defaultPickup', 'savedPlaces', 'updatedAt']);
      allow delete: if false;
    }

    match /drivers/{driverId} {
      allow read: if driverProfileMatchesAuth(driverId) || isAdmin()
        || (isFleetOwner() && resource.data.fleetId is string && fleetOwnedByCaller(resource.data.fleetId));
      allow create: if owns(driverId)
        && request.resource.data.uid == driverId
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.role == 'driver'
        && request.resource.data.driverType in ['individual', 'fleet', 'enterprise']
        && request.resource.data.verificationStatus == 'notStarted'
        && request.resource.data.accountStatus == 'pending'
        && request.resource.data.canReceiveRides == false
        && request.resource.data.isOnline == false;
      allow update: if driverProfileMatchesAuth(driverId)
        && request.resource.data.uid == resource.data.uid
        && (
          request.resource.data.authUid == resource.data.authUid
          || (
            resource.data.authUid == null
            && request.resource.data.authUid == request.auth.uid
          )
        )
        && request.resource.data.role == resource.data.role
        && request.resource.data.accountStatus == resource.data.accountStatus
        && request.resource.data.canGoOnline == resource.data.canGoOnline
        && request.resource.data.canReceiveRides == resource.data.canReceiveRides
        && request.resource.data.commissionWalletStatus == resource.data.commissionWalletStatus
        && request.resource.data.commissionWalletId == resource.data.commissionWalletId
        && request.resource.data.commissionWalletOwnerType == resource.data.commissionWalletOwnerType
        && request.resource.data.payoutOwner == resource.data.payoutOwner
        && (
          request.resource.data.mustChangePassword == resource.data.mustChangePassword
          || (
            resource.data.mustChangePassword == true
            && request.resource.data.mustChangePassword == false
          )
        )
        && (
          request.resource.data.firstLoginCompleted == resource.data.firstLoginCompleted
          || request.resource.data.firstLoginCompleted == true
        )
        && request.resource.data.rating == resource.data.rating
        && request.resource.data.totalTrips == resource.data.totalTrips
        && request.resource.data.totalEarnings == resource.data.totalEarnings
        && request.resource.data.walletBalance == resource.data.walletBalance
        && validDriverVerificationTransition()
        && (
          request.resource.data.isOnline == false
          || (
            resource.data.verificationStatus == 'approved'
            && resource.data.canReceiveRides == true
            && resource.data.accountStatus == 'active'
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullName',
          'phoneNumber',
          'email',
          'authUid',
          'profileImageUrl',
          'profilePhotoPath',
          'vehicleType',
          'vehicleModel',
          'vehiclePlateNumber',
          'vehicleColor',
          'numberOfSeats',
          'cityRegion',
          'vehicleId',
          'defaultVehicleId',
          'vehicleSummary',
          'payoutOwner',
          'payoutAccountId',
          'mustChangePassword',
          'firstLoginCompleted',
          'verificationStatus',
          'onboardingStep',
          'onboardingComplete',
          'isOnline',
          'isAvailable',
          'status',
          'currentRideId',
          'currentRideStatus',
          'fcmToken',
          'updatedAt',
          'lastSeenAt'
        ]);
      allow create, update: if isAdmin();
      allow create: if isFleetOwner()
        && request.resource.data.driverType in ['fleet', 'enterprise']
        && request.resource.data.fleetId is string
        && fleetOwnedByCaller(request.resource.data.fleetId)
        && request.resource.data.createdBy in ['fleet_owner', 'admin']
        && request.resource.data.accountStatus in ['pending', 'active']
        && request.resource.data.canReceiveRides == false;
      allow update: if isFleetOwner()
        && resource.data.fleetId is string
        && fleetOwnedByCaller(resource.data.fleetId)
        && request.resource.data.fleetId == resource.data.fleetId
        && request.resource.data.authUid == resource.data.authUid;
      allow delete: if false;
    }

    match /driver_verifications/{driverId} {
      allow read: if driverProfileMatchesAuth(driverId) || isAdmin();
      // CREATE: driver seeding initial doc ('notStarted') or first-time submission ('pending').
      allow create: if (owns(driverId) || driverProfileMatchesAuth(driverId))
        && request.resource.data.driverId == driverId
        && request.resource.data.status in ['notStarted', 'pending'];
      // UPDATE: allow submission from any pre-review state, or resubmission after rejection.
      allow update: if driverProfileMatchesAuth(driverId)
        && resource.data.driverId == driverId
        && resource.data.status in ['notStarted', 'rejected', 'resubmissionRequired']
        && request.resource.data.driverId == driverId
        && request.resource.data.status == 'pending'
        && request.resource.data.reviewedBy == null
        && request.resource.data.reviewedAt == null;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /driver_vehicles/{vehicleId} {
      allow read: if isRider()
        || isAdmin()
        || (isDriver() && driverProfileMatchesAuth(resource.data.driverId));
      allow create: if isDriver()
        && driverProfileMatchesAuth(request.resource.data.driverId);
      allow update: if isDriver()
        && driverProfileMatchesAuth(resource.data.driverId)
        && request.resource.data.driverId == resource.data.driverId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'vehicleType',
          'model',
          'plateNumber',
          'plateType',
          'color',
          'seats',
          'isDefault',
          'updatedAt'
        ]);
      allow create, update, delete: if isAdmin();
    }

    match /driver_documents/{documentId} {
      allow read: if isAdmin()
        || (isDriver() && driverProfileMatchesAuth(resource.data.driverId));
      allow create: if isDriver()
        && driverProfileMatchesAuth(request.resource.data.driverId)
        && request.resource.data.status == 'uploaded';
      allow update, delete: if isAdmin();
    }

    match /ride_requests/{requestId} {
      allow create: if isRider()
        && request.resource.data.requestId == requestId
        && request.resource.data.riderId == request.auth.uid
        && request.resource.data.status in ['requested', 'searching_driver']
        && request.resource.data.assignedDriverId == null;
      allow read: if isAdmin()
        || (isRider() && resource.data.riderId == request.auth.uid)
        || (
          isDriver()
          && resource.data.assignedDriverId is string
          && driverProfileMatchesAuth(resource.data.assignedDriverId)
        );
      allow update: if isRider()
        && resource.data.riderId == request.auth.uid
        && request.resource.data.riderId == request.auth.uid
        && request.resource.data.status in ['cancelled_by_rider', 'cancelled_by_driver']
        && request.resource.data.cancelledBy == 'rider'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'cancelledBy',
          'cancellationReason',
          'updatedAt'
        ]);
      allow update: if isDriver()
        && resource.data.assignedDriverId is string
        && driverProfileMatchesAuth(resource.data.assignedDriverId)
        && (
          (
            resource.data.status in ['searching_driver', 'requested_specific_driver']
            && request.resource.data.status in ['searching_driver', 'driver_rejected']
            && request.resource.data.assignedDriverId == null
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'status',
                'assignedDriverId',
                'lastRejectedDriverId',
                'rejectedDriverIds',
                'updatedAt'
              ])
          )
          || (
            resource.data.status in ['searching_driver', 'requested_specific_driver']
            && request.resource.data.status == 'driver_assigned'
            && request.resource.data.assignedDriverId == resource.data.assignedDriverId
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'status',
                'assignedDriverId',
                'assignedRideId',
                'updatedAt'
              ])
          )
          || (
            validRideTransition(
              resource.data.status,
              request.resource.data.status
            )
            && request.resource.data.assignedDriverId == resource.data.assignedDriverId
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt', 'cancellationReason', 'cancelledBy'])
          )
        );
    }

    match /rides/{rideId} {
      allow read: if isAdmin()
        || (isRider() && resource.data.riderId == request.auth.uid)
        || (isDriver() && driverProfileMatchesAuth(resource.data.driverId));
      allow create: if isDriver()
        && request.resource.data.rideId == rideId
        && driverProfileMatchesAuth(request.resource.data.driverId)
        && request.resource.data.status == 'driver_assigned'
        && request.resource.data.keys().hasOnly([
          'rideId',
          'requestId',
          'riderId',
          'driverId',
          'driverSnapshot',
          'pickupLocation',
          'destinationLocation',
          'distanceKm',
          'estimatedDurationMinutes',
          'selectedRideType',
          'estimatedFare',
          'finalFare',
          'currency',
          'status',
          'paymentStatus',
          'paymentMethod',
          'payoutOwner',
          'payoutAccountId',
          'commissionPolicyId',
          'commissionDeducted',
          'commissionAmount',
          'platformCommissionPercentage',
          'createdAt',
          'acceptedAt',
          'startedAt',
          'completedAt',
          'cancelledAt'
        ]);
      allow update: if isDriver()
        && driverProfileMatchesAuth(resource.data.driverId)
        && request.resource.data.driverId == resource.data.driverId
        && validRideTransition(
          resource.data.status,
          request.resource.data.status
        )
        && (
          (
            request.resource.data.status in ['driver_arriving', 'driver_arrived']
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status'])
          )
          || (
            request.resource.data.status == 'in_progress'
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'startedAt'])
          )
          || (
            request.resource.data.status == 'completed'
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'status',
                'finalFare',
                'paymentStatus',
                'completedAt'
              ])
            && (
              request.resource.data.paymentStatus == resource.data.paymentStatus
              || (
                resource.data.paymentMethod == 'cash'
                && request.resource.data.paymentStatus == 'paid'
              )
              || (
                resource.data.paymentMethod != 'cash'
                && request.resource.data.paymentStatus == 'pending'
              )
            )
          )
          || (
            request.resource.data.status in ['cancelled_by_driver', 'cancelled_by_rider']
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'cancelledAt', 'cancellationReason', 'cancelledBy'])
          )
        );
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /driver_live_locations/{driverId} {
      allow write: if driverProfileMatchesAuth(driverId)
        && request.resource.data.driverId == driverId;
      allow read: if driverProfileMatchesAuth(driverId) || isAdmin()
        || (
          isRider()
          && resource.data.driverId == driverId
          && resource.data.currentRideId is string
          && (
            (
              requestBelongsToRider(resource.data.currentRideId)
              && get(/databases/$(database)/documents/ride_requests/$(resource.data.currentRideId)).data.assignedDriverId == driverId
            )
            || (
              rideBelongsToRider(resource.data.currentRideId)
              && get(/databases/$(database)/documents/rides/$(resource.data.currentRideId)).data.driverId == driverId
            )
          )
        );
    }

    match /rider_live_locations/{riderId} {
      allow write: if owns(riderId);
      allow read: if owns(riderId) || isAdmin()
        || (
          isDriver()
          && resource.data.currentRideId is string
          && exists(/databases/$(database)/documents/rides/$(resource.data.currentRideId))
          && driverProfileMatchesAuth(get(/databases/$(database)/documents/rides/$(resource.data.currentRideId)).data.driverId)
          && get(/databases/$(database)/documents/rides/$(resource.data.currentRideId)).data.riderId == riderId
          && get(/databases/$(database)/documents/rides/$(resource.data.currentRideId)).data.status in [
            'driver_assigned',
            'driver_arriving',
            'driver_arrived',
            'in_progress'
          ]
        );
    }

    match /pricing_rules/{ruleId} {
      allow read: if signedIn() && resource.data.isActive == true;
      allow write: if isAdmin();
    }

    match /driver_wallets/{driverId} {
      allow read: if driverProfileMatchesAuth(driverId) || isAdmin();
      allow write: if isAdmin();
    }

    match /fleets/{fleetId} {
      allow read: if isAdmin()
        || fleetOwnedByCaller(fleetId)
        || (
          isDriver()
          && resource.data.authorizedAuthUids[request.auth.uid] == true
        );
      allow create, update: if isAdmin()
        || (
          isFleetOwner()
          && request.resource.data.fleetOwnerId == request.auth.uid
        );
      allow delete: if isAdmin();
    }

    match /fleet_drivers/{driverId} {
      allow read: if isAdmin()
        || driverProfileMatchesAuth(driverId)
        || (
          resource.data.fleetId is string
          && fleetOwnedByCaller(resource.data.fleetId)
        );
      allow create, update: if isAdmin()
        || (
          request.resource.data.fleetId is string
          && fleetOwnedByCaller(request.resource.data.fleetId)
        );
      allow delete: if isAdmin();
    }

    match /driver_public_profiles/{driverId} {
      allow read: if signedIn();
      allow create: if isAdmin()
        || (
          driverProfileMatchesAuth(driverId)
          && request.resource.data.driverId == driverId
          && request.resource.data.keys().hasOnly([
            'driverId',
            'fullName',
            'rating',
            'totalTrips',
            'vehicleType',
            'vehicleModel',
            'vehicleColor',
            'driverType',
            'fleetName',
            'updatedAt'
          ])
        );
      allow update: if isAdmin()
        || (
          driverProfileMatchesAuth(driverId)
          && request.resource.data.driverId == driverId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'driverId',
            'fullName',
            'rating',
            'totalTrips',
            'vehicleType',
            'vehicleModel',
            'vehicleColor',
            'driverType',
            'fleetName',
            'updatedAt'
          ])
        );
      allow delete: if isAdmin();
    }

    match /commission_wallets/{walletId} {
      allow read: if isAdmin()
        || (
          isDriver()
          && resource.data.ownerType == 'driver'
          && driverProfileMatchesAuth(resource.data.ownerId)
        )
        || (
          isDriver()
          && resource.data.ownerType in ['fleet', 'enterprise']
          && resource.data.authorizedAuthUids[request.auth.uid] == true
        )
        || (
          resource.data.ownerType in ['fleet', 'enterprise']
          && fleetOwnedByCaller(resource.data.ownerId)
        );
      allow write: if isAdmin();
    }

    match /commission_transactions/{transactionId} {
      allow read: if isAdmin()
        || (
          isDriver()
          && resource.data.driverId is string
          && driverProfileMatchesAuth(resource.data.driverId)
        )
        || (
          isFleetOwner()
          && resource.data.fleetId is string
          && fleetOwnedByCaller(resource.data.fleetId)
        );
      allow write: if isAdmin();
    }

    match /payout_accounts/{accountId} {
      allow read: if isAdmin()
        || (
          isDriver()
          && resource.data.ownerType == 'driver'
          && driverProfileMatchesAuth(resource.data.ownerId)
        )
        || (
          resource.data.ownerType in ['fleet', 'enterprise']
          && fleetOwnedByCaller(resource.data.ownerId)
        );
      allow create: if isAdmin()
        || (
          isDriver()
          && request.resource.data.ownerType == 'driver'
          && driverProfileMatchesAuth(request.resource.data.ownerId)
          && request.resource.data.status == 'pending'
          && request.resource.data.keys().hasOnly([
            'accountId',
            'ownerType',
            'ownerId',
            'provider',
            'accountName',
            'accountNumber',
            'status',
            'isDefault',
            'createdAt',
            'updatedAt'
          ])
        )
        || (
          request.resource.data.ownerType in ['fleet', 'enterprise']
          && fleetOwnedByCaller(request.resource.data.ownerId)
        );
      allow update: if isAdmin()
        || (
          isDriver()
          && resource.data.ownerType == 'driver'
          && driverProfileMatchesAuth(resource.data.ownerId)
          && request.resource.data.ownerType == resource.data.ownerType
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'provider',
            'accountName',
            'accountNumber',
            'status',
            'isDefault',
            'updatedAt'
          ])
        )
        || (
          request.resource.data.ownerType in ['fleet', 'enterprise']
          && fleetOwnedByCaller(request.resource.data.ownerId)
        );
      allow delete: if isAdmin();
    }

    match /driver_devices/{deviceId} {
      allow read: if signedIn()
        && resource.data.authUid == request.auth.uid;
      allow create, update: if signedIn()
        && request.resource.data.authUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /driver_transactions/{transactionId} {
      allow read: if isAdmin()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isDriver()
        && request.resource.data.transactionId == transactionId
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.type == 'withdrawal'
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['read']);
      allow create, delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if isRider()
        && request.resource.data.ticketId == ticketId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role == 'rider'
        && request.resource.data.status == 'open';
      allow read: if isRider() && resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /driver_support_tickets/{ticketId} {
      allow create: if isDriver()
        && request.resource.data.ticketId == ticketId
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.status == 'open';
      allow read: if isAdmin()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /sos_alerts/{alertId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'active';
      allow read, update, delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow create: if isRider()
        && request.resource.data.riderId == request.auth.uid;
      allow read: if isRider() && resource.data.riderId == request.auth.uid;
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /driver_activity_logs/{logId} {
      allow create: if isDriver()
        && request.resource.data.logId == logId
        && request.resource.data.driverId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isRider()
        && (
          resource.data.riderId == request.auth.uid
          || resource.data.userId == request.auth.uid
        );
      allow write: if isAdmin();
    }

    match /safety_reports/{reportId} {
      allow create: if isRider()
        && request.resource.data.reportId == reportId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role == 'rider'
        && request.resource.data.status == 'submitted';
      allow read: if isRider() && resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /system_settings/{settingId} {
      allow read: if signedIn() && resource.data.isPublic == true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
